{
  "name": "avocado-studio",
  "private": true,
  "version": "0.0.1",
  "description": "AI-powered content operations for websites — natural language editing with live preview, type-safe operations, and multi-model AI support",
  "license": "Apache-2.0",
  "keywords": [
    "ai",
    "website-editor",
    "content-ops",
    "chat",
    "nextjs",
    "cms",
    "blocks"
  ],
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @ai-site-editor/site --filter @ai-site-editor/editor --filter @ai-site-editor/orchestrator dev",
    "dev:ctl": "./scripts/devctl.sh",
    "dev:start": "./scripts/devctl.sh start --wait",
    "dev:stop": "./scripts/devctl.sh stop",
    "dev:restart": "./scripts/devctl.sh restart --wait",
    "dev:status": "./scripts/devctl.sh status",
    "dev:logs": "./scripts/devctl.sh logs",
    "dev:doctor": "./scripts/devctl.sh doctor",
    "dev:setup": "./scripts/dev-setup.sh",
    "demo:avocado:check": "./scripts/demo-avocado-check.sh",
    "demo:60s:human": "./scripts/demo-60s-humanized-playwright.sh",
    "docs:c4:render": "./scripts/render-c4.sh",
    "dev:site": "pnpm --filter @ai-site-editor/site dev",
    "dev:editor": "pnpm --filter @ai-site-editor/editor dev",
    "dev:orchestrator": "pnpm --filter @ai-site-editor/orchestrator dev",
    "dev:contentful-marketing": "pnpm --filter contentful-marketing-site dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "test:unit": "pnpm --filter @ai-site-editor/orchestrator test:unit && pnpm --filter @ai-site-editor/blocks test",
    "test:e2e": "pnpm --filter @ai-site-editor/orchestrator test:e2e",
    "vercel:env:check": "./scripts/vercel-env-check.sh all",
    "vercel:env:site": "./scripts/vercel-env-check.sh site",
    "vercel:env:editor": "./scripts/vercel-env-check.sh editor"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
