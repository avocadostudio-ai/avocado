{
  "name": "@ai-site-editor/orchestrator",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test tsx --test --test-concurrency=4 src/**/*.test.ts",
    "coverage": "NODE_ENV=test c8 --reporter=text-summary --reporter=text tsx --test --test-concurrency=4 src/**/*.test.ts",
    "benchmark:models": "tsx src/scripts/benchmark-models.ts",
    "benchmark:compact-context": "tsx src/scripts/benchmark-compact-context.ts",
    "benchmark:ops": "tsx src/scripts/benchmark-models.ts --eval-mode ops-json --prompts src/scripts/test-sets/all-commands.json --runs 1 --variants 5",
    "benchmark:ops:multi": "tsx src/scripts/benchmark-models.ts --eval-mode ops-json --ops-cardinality multi --prompts src/scripts/test-sets/all-commands.json --runs 1 --variants 5",
    "benchmark:ops:sonnet": "tsx src/scripts/benchmark-models.ts --provider anthropic --model claude-sonnet-4-20250514 --eval-mode ops-json --prompts src/scripts/test-sets/all-commands.json --runs 1 --variants 5"
  },
  "dependencies": {
    "@ai-site-editor/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "googleapis": "^171.4.0",
    "openai": "^4.87.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "c8": "^10.1.3",
    "typescript": "^5.7.3"
  }
}
