# Orchestrator URL (defaults to http://localhost:4200)
ORCHESTRATOR_URL=http://localhost:4200

# Secret for enabling draft mode (also accepts VITE_SITE_DRAFT_SECRET so you
# can share one .env between site and editor)
DRAFT_MODE_SECRET=dev-secret

# Editor origin for preview bridge (optional, defaults to http://localhost:4100)
NEXT_PUBLIC_EDITOR_ORIGIN=http://localhost:4100

# Default site identity
NEXT_PUBLIC_DEFAULT_SITE_ID=avocado-stories
NEXT_PUBLIC_SITE_NAME=Avocado Stories
