{
  "name": "@ai-site-editor/site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev -p 3000",
    "build": "node ./scripts/sync-published-content.mjs && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --test --experimental-strip-types --experimental-specifier-resolution=node test/**/*.test.ts"
  },
  "dependencies": {
    "@ai-site-editor/blocks": "workspace:*",
    "@ai-site-editor/preview-adapter": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "lucide-react": "^0.575.0",
    "next": "15.2.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.7.3"
  }
}
