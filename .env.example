# ============================================================
# REQUIRED — at least one API key needed (omit both for demo mode)
# ============================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Demo mode ------------------------------------------------
# When DEMO_MODE=1 the orchestrator becomes a "try before you sign up"
# playground using YOUR API key, locked to a single operation type.
# - Only Hero block `update_props` ops are allowed (everything else rejected).
# - Each visitor gets an isolated ephemeral session keyed by a hash of their IP.
# - /agent/*, /sites-agent/*, /jira/* are hard-blocked.
# - Image generation (DALL-E / Unsplash) is disabled.
# - Per-IP rate limit: 20 chat+ops requests per hour (override below).
# See apps/orchestrator/src/demo-mode.ts for the gate implementation.
DEMO_MODE=0
DEMO_ALLOWED_OPS=update_props                  # comma-separated op types
DEMO_ALLOWED_BLOCK_TYPES=Hero                  # comma-separated block types
DEMO_RATE_LIMIT_PER_IP_PER_HOUR=20             # chat + ops requests per IP/hour
DEMO_DISABLE_IMAGE_GEN=1                       # 1 = no DALL-E / Unsplash in demo

# ============================================================
# OPTIONAL — sensible defaults below, override as needed
# ============================================================

# --- Model overrides (defaults work out of the box) ---
OPENAI_MODEL_KEY=balanced
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_BALANCED=gpt-4o
OPENAI_MODEL_REASONING=o1
OPENAI_MODEL_CODEX=o3

ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6
ANTHROPIC_MODEL_CODEX=claude-opus-4-6

# --- Agent mode (server-side key, enables agentic editing via /agent/* routes) ---
AGENT_API_KEY=                               # Anthropic (sk-ant-...) or OpenAI (sk-...) key
# AGENT_ANTHROPIC_MODEL=claude-sonnet-4-6   # Anthropic model for agent mode
# AGENT_OPENAI_MODEL=gpt-4o                 # OpenAI model for agent mode
# AGENT_MAX_TOKENS=16384                    # Max output tokens per agent turn
# AGENT_TEMPERATURE=0                       # 0 = deterministic edits
# AGENT_MAX_TOOL_CALLS=20                   # Max tool calls per agent session
# AGENT_THINKING_BUDGET=10000               # Extended thinking token budget (0 = disabled, auto-detects complex requests)

# --- Image generation & transcription ---
# IMAGE_GEN_PROVIDER=openai     # openai (default) | gemini
OPENAI_IMAGE_MODEL=gpt-image-1
# GOOGLE_GENAI_API_KEY=
# GOOGLE_GENAI_IMAGE_MODEL=gemini-2.5-flash-image
# GOOGLE_GENAI_MODEL_FAST=gemini-2.5-flash
# GOOGLE_GENAI_MODEL_BALANCED=gemini-2.5-flash
# GOOGLE_GENAI_MODEL_REASONING=gemini-2.5-pro
# GOOGLE_GENAI_MODEL_CODEX=gemini-2.5-pro
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIBE_FALLBACK_MODELS=gpt-4o-transcribe,whisper-1
UNSPLASH_ACCESS_KEY=

# --- Chat pipeline flags (all default ON — see CLAUDE.md for details) ---
CHAT_STRICT_PRIMARY_OP_MODE=0
CHAT_PARALLEL_PLANNER=1
CHAT_ROUTER_HEAD_START_MS=200
CHAT_DEFER_IMAGE_RESOLUTION=1
CHAT_STREAMED_OP_APPLY=1

# --- Local service URLs (no changes needed for default setup) ---
ORCHESTRATOR_URL=http://localhost:4200
ORCHESTRATOR_PUBLIC_ORIGIN=http://localhost:4200

# Public origin of the Next.js site (the one that renders pages), used to build
# preview links posted back to Jira tickets. Override for production.
SITE_PUBLIC_ORIGIN=http://localhost:3000
ORCHESTRATOR_CORS_ORIGINS=http://localhost:3000,http://localhost:4100
VITE_SITE_ORIGIN=http://localhost:3000
VITE_ORCHESTRATOR_URL=http://localhost:4200
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_EDITOR_ORIGIN=http://localhost:4100

# --- Site defaults ---
SITE_RENDER_MODE=static
SITE_PUBLISH_SESSION=dev
SITE_PUBLISH_SITE_ID=avocado-stories
NEXT_PUBLIC_DEFAULT_SITE_ID=avocado-stories
NEXT_PUBLIC_ENABLE_EDITOR=0
DRAFT_DEFAULT_SESSION=dev

# --- Orchestrator tuning ---
# Paths below default to ../../.data/* relative to apps/orchestrator.
# When running the orchestrator in Docker, override them to live under a mounted
# volume, e.g.:
#   ORCHESTRATOR_STATE_FILE=/app/.data/orchestrator-state.json
#   CHAT_TELEMETRY_FILE=/app/.data/chat-telemetry.ndjson
#   ORCHESTRATOR_GENERATED_IMAGE_DIR=/app/.data/generated-images
ORCHESTRATOR_STATE_FILE=
ORCHESTRATOR_GENERATED_IMAGE_DIR=
ORCHESTRATOR_STATE_BACKUP_LIMIT=40
ORCHESTRATOR_STATE_BACKUP_MIN_INTERVAL_MS=120000

# --- Auth & secrets (omit to disable) ---
# Draft mode secret — set ONE of these (both site and editor accept either name):
#   DRAFT_MODE_SECRET    (conventional for the site)
#   VITE_SITE_DRAFT_SECRET (conventional for the editor, also works on site)
DRAFT_MODE_SECRET=
# Enables orchestrator access gate for chat/ops endpoints when set.
ACCESS_PASSWORD_HASH=
# Generate password hash: echo -n "yourpassword" | shasum -a 256

# --- Publishing (omit for local-only development) ---
PUBLISH_MODE=git
PUBLISH_GIT_BRANCH=main
PUBLISH_GIT_STRICT=0
# Publish auth token — same value must be set as PUBLISH_TOKEN on site/orchestrator
# and as VITE_PUBLISH_TOKEN on the editor. Omit to disable publish protection.
PUBLISH_TOKEN=
VITE_PUBLISH_TOKEN=
VERCEL_DEPLOY_HOOK_URL=

# --- External media sources (omit to skip) ---
# Google Drive — share a folder for brand assets
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_API_KEY=

# Contentful — browse space assets in the editor
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# --- Migration agent ---
# PUPPETEER_EXECUTABLE_PATH=        # Custom Chrome/Chromium path for Puppeteer (CI/Docker)
SITES_AGENT_MAX_BUDGET_USD=2

# --- JIRA integration (omit to disable) ---
# JIRA_BASE_URL=                        # e.g. https://mycompany.atlassian.net
# JIRA_USER_EMAIL=                      # For Basic auth (Cloud)
# JIRA_API_TOKEN=                       # API token (Cloud) or PAT (Server/DC)
# JIRA_WEBHOOK_SECRET=                  # Shared secret for webhook validation
# JIRA_AGENT_ACCOUNT_ID=                # JIRA account ID of the agent user (for @mention + self-loop guard)
#
# 3-stage workflow (see docs: review → execute → publish)
# JIRA_REVIEW_STATUS=To Do              # Status for tickets pending review + approval (also legacy: JIRA_TRIGGER_STATUS)
# JIRA_EXECUTE_STATUS=In Progress       # Status the agent sets while applying edits
# JIRA_PREVIEW_STATUS=In Review         # Status after draft is ready; reporter reviews + approves
# JIRA_DONE_STATUS=Done                 # Terminal status after publish
# JIRA_FAILED_STATUS=                   # Optional: status to transition to on failure
# JIRA_MAX_REVIEW_PASSES=3              # Cap on clarification rounds per ticket
#
# JIRA_SITE_ID=avocado-stories          # Fallback siteId when no sites are registered yet — NOT a lock.
                                        # With multiple registered sites, the agent always asks unless the
                                        # ticket text names one (or there's only one registered).
# JIRA_SESSION=dev                      # Session shared with the editor. Leave as "dev" (editor's default)
                                        # so Jira edits appear live in the editor view.
# JIRA_AUTO_PUBLISH=0                   # 1 = skip In Review, publish + close immediately after execute
# JIRA_POLL_ENABLED=0                   # Enable polling mode (alternative to webhooks)
# JIRA_POLL_JQL=                        # JQL filter (default: status in review+preview statuses)
# JIRA_POLL_INTERVAL_MS=60000           # Polling interval in ms

# --- Experimental ---
VITE_ENABLE_PATCH_TRANSPORT=0
VITE_ANCHORED_COMPOSER=0

# --- Editor dev options ---
# When set to 1, the Settings panel shows developer-only toggles
# (Streaming, Nested labels, Field draft telemetry, Debug mode) and the
# panel title becomes "Developer mode". Leave unset/0 for end users.
# Runtime escape hatch: append ?dev=1 to the editor URL to enable and
# persist across sessions (stored in localStorage). Use ?dev=0 to undo.
VITE_SHOW_DEV_OPTIONS=0
