{
  "name": "@ai-site-editor/preview-adapter",
  "version": "0.0.2",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/preview-bridge-core.tsx",
    "./styles.css": "./src/styles.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/avocadostudio-ai/avocado.git",
    "directory": "packages/preview-adapter"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./core": {
        "import": "./dist/preview-bridge-core.js",
        "types": "./dist/preview-bridge-core.d.ts"
      },
      "./styles.css": "./src/styles.css"
    }
  },
  "files": ["dist", "src/styles.css"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@avocadostudio-ai/shared": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "typescript": "^5.7.3"
  }
}
