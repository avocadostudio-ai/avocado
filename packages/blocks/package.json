{
  "name": "@avocadostudio-ai/blocks",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/blocks/styles.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/avocadostudio-ai/avocado.git",
    "directory": "packages/blocks"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/blocks/styles.css"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-css.mjs",
    "test": "NODE_ENV=test tsx --test src/blocks/*/renderer.test.ts",
    "test:unit": "NODE_ENV=test tsx --test src/blocks/*/renderer.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@avocadostudio-ai/shared": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.10",
    "next": "^15.5.15",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
