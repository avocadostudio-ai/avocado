{
  "name": "@ai-site-editor/site-sdk",
  "version": "0.0.2",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./editor-manifest": "./src/editor-manifest.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-site-editor/ai-site-editor.git",
    "directory": "packages/site-sdk"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./editor-manifest": {
        "import": "./dist/editor-manifest.js",
        "types": "./dist/editor-manifest.d.ts"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-site-editor/preview-adapter": "workspace:*",
    "@ai-site-editor/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "typescript": "^5.7.3"
  }
}
