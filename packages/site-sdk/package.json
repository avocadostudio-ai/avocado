{
  "name": "@ai-site-editor/site-sdk",
  "version": "0.0.2",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "avocado-register": "./dist/cli/register.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./draft": "./src/draft.ts",
    "./draft/core": "./src/draft-context-core.ts",
    "./editor": "./src/editor.ts",
    "./routes": "./src/routes.ts",
    "./routes/core": "./src/draft-routes-core.ts",
    "./editor-manifest": "./src/editor-manifest.ts",
    "./publish-handlers/json-file": "./src/publish-handlers/json-file.ts",
    "./middleware": "./src/middleware.ts",
    "./navigation": "./src/navigation.ts",
    "./page": "./src/create-site-page.tsx"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-site-editor/ai-site-editor.git",
    "directory": "packages/site-sdk"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./draft": {
        "import": "./dist/draft.js",
        "types": "./dist/draft.d.ts"
      },
      "./editor": {
        "import": "./dist/editor.js",
        "types": "./dist/editor.d.ts"
      },
      "./routes": {
        "import": "./dist/routes.js",
        "types": "./dist/routes.d.ts"
      },
      "./editor-manifest": {
        "import": "./dist/editor-manifest.js",
        "types": "./dist/editor-manifest.d.ts"
      },
      "./draft/core": {
        "import": "./dist/draft-context-core.js",
        "types": "./dist/draft-context-core.d.ts"
      },
      "./routes/core": {
        "import": "./dist/draft-routes-core.js",
        "types": "./dist/draft-routes-core.d.ts"
      },
      "./publish-handlers/json-file": {
        "import": "./dist/publish-handlers/json-file.js",
        "types": "./dist/publish-handlers/json-file.d.ts"
      },
      "./middleware": {
        "import": "./dist/middleware.js",
        "types": "./dist/middleware.d.ts"
      },
      "./navigation": {
        "import": "./dist/navigation.js",
        "types": "./dist/navigation.d.ts"
      },
      "./page": {
        "import": "./dist/create-site-page.js",
        "types": "./dist/create-site-page.d.ts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-site-editor/blocks": "workspace:*",
    "@ai-site-editor/preview-adapter": "workspace:*",
    "@ai-site-editor/shared": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "typescript": "^5.7.3"
  }
}
